{
  "name": "smartcampus-erp",
  "version": "1.0.0",
  "description": "Full-stack MERN College ERP System",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "build": "cd client && npm run build && cd .. && rm -rf build && cp -r client/build build",
    "start:client": "cd client && npm start",
    "start:api": "cd server && npm start",
    "dev": "concurrently \"npm run start:client\" \"npm run start:api\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.0",
    "pdfkit": "^0.14.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}

{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/build",
        "buildCommand": "npm run build",
        "zeroConfig": false
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "zeroConfig": false
      }
    }
  ],
  "routes": [
    {
      "src": "^/api(/.*)?$",
      "dest": "/api/index.js"
    },
    {
      "src": "/.*",
      "dest": "/client/index.html"
    }
  ]
}
